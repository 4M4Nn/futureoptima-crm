PORT=7000
NODE_ENV=production
FRONTEND_URL=https://futureoptima-crm.vercel.app

DATABASE_URL=postgresql://your-neon-url?sslmode=require

JWT_SECRET=your-64-char-secret-here
JWT_EXPIRES_IN=7d

GROQ_API_KEY=your_groq_api_key_from_console.groq.com
GROQ_MODEL=llama-3.1-8b-instant

# Meta / Facebook Lead Ads & WhatsApp Business
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
META_ACCESS_TOKEN=your-page-access-token
META_VERIFY_TOKEN=futureoptima_meta_2025
META_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
META_WABA_ID=your-whatsapp-business-account-id

# Webhook URLs (for reference)
# Lead Form Ads:       https://your-backend.onrender.com/api/meta/webhook
# Click-to-WhatsApp:   https://your-backend.onrender.com/api/meta/wa-webhook

# Institute Details (used in PDF receipts)
INSTITUTE_NAME=Future Optima IT Solutions
INSTITUTE_ADDRESS=Kakkanad, Kochi, Kerala - 682030
INSTITUTE_PHONE=+91-8891129333
INSTITUTE_EMAIL=info@futureoptimaitsolutions.com
INSTITUTE_WEBSITE=https://futureoptima.in
